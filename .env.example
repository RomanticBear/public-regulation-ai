# OpenAI API Key (검색 embedding + AI 답변 요약 모두 사용)
OPENAI_API_KEY=sk-your-key-here

# Supabase PostgreSQL (Session pooler URI 권장 — Dashboard > Database > Connection string)
DATABASE_URL=postgresql://postgres.emjypaorpmitjhemmvyh:YOUR_PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_SSL_VERIFY=false
SUPABASE_DB_MODE=pooler

# LLM 모델 (답변 생성)
OPENAI_MODEL=gpt-4o-mini

# Embedding 모델 (조문 벡터 검색)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 회사망 SSL 프록시 환경이면 false
OPENAI_SSL_VERIFY=false
